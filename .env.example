# PostgreSQL（docker compose 使用）
POSTGRES_USER=flight
POSTGRES_PASSWORD=flight_dev_pw   # 部署時請換強密碼：openssl rand -hex 16
POSTGRES_DB=flight_tracker
DATABASE_URL=postgresql://flight:flight_dev_pw@db:5432/flight_tracker?schema=public

# 後端
SERVER_PORT=3001

# 資料來源：mock | duffel | ignav | google-flights | skyscanner | trip
FLIGHT_PROVIDER=mock
# 多來源優先序鏈（逗號分隔，依序查詢取全域最低價）
# PROVIDER_CHAIN=google-flights,ignav

# 各來源每月搜尋次數上限（達標後自動跳過，以保護免費額度）
# IGNAV_SEARCH_LIMIT=900        # Ignav 免費 ~1,000 次/月，建議保留緩衝
# GOOGLE_FLIGHTS_SEARCH_LIMIT=  # 無 API 額度，不需設定
# DUFFEL_SEARCH_LIMIT=1000

# Ignav（免費機票價格 API；ignav.com 註冊取得，免信用卡）
IGNAV_API_KEY=
IGNAV_MARKET=TW

# GitHub Actions / 外部排程觸發 /api/run-all 的保護金鑰（必填，否則端點拒絕所有請求）
# 產生方式：openssl rand -hex 32
RUN_SECRET=

# CORS 允許來源（預設 localhost:5173；部署時改為實際前端網址）
# CORS_ORIGIN=http://your-server-ip:5173

# Duffel（選用）
# DUFFEL_API_TOKEN=duffel_test_...

# Web Push（VAPID，以 web-push 產生）
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# 前端
VITE_API_BASE_URL=http://localhost:3001
