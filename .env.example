# PostgreSQL（docker compose 使用）
POSTGRES_USER=flight
POSTGRES_PASSWORD=flight_dev_pw
POSTGRES_DB=flight_tracker
DATABASE_URL=postgresql://flight:flight_dev_pw@db:5432/flight_tracker?schema=public

# 後端
SERVER_PORT=3001
# 資料來源：mock | duffel | ignav | google-flights | skyscanner | trip
FLIGHT_PROVIDER=mock
# 多來源優先序鏈（逗號分隔，會自動把 mock 加在最後當保底）。
# 設定後會覆蓋 FLIGHT_PROVIDER。多來源範例：
# PROVIDER_CHAIN=google-flights,ignav,mock
# 各來源每月搜尋次數上限（控成本/避免過度爬蟲），達標後自動跳過該來源
# DUFFEL_SEARCH_LIMIT=1000
# IGNAV_SEARCH_LIMIT=1000
# 各來源每月搜尋次數上限（達標後自動跳過，以保護免費額度）
# Ignav 免費額度約 1,000 次/月，MAX_QUERIES_PER_RUN=60 → 每月最多 16 輪 → 建議每 2 天一次
# Google Flights 無 API 額度，每小時均可執行
# IGNAV_SEARCH_LIMIT=900        # 保留緩衝，每次 60 queries → 最多 15 輪/月（每 2 天一次）
# GOOGLE_FLIGHTS_SEARCH_LIMIT=720

# Ignav（免費機票價格 API；ignav.com 註冊取得，免信用卡）
IGNAV_API_KEY=
# Ignav 報價的市場/幣別國別（2 碼）；當所選幣別對不到內建對照表時的預設
IGNAV_MARKET=TW

# GitHub Actions 觸發 /api/run-all 的保護金鑰（留空則不驗證）
RUN_SECRET=

# Duffel（正式資料源，之後填入）
DUFFEL_API_TOKEN=

# Ignav（免費機票價格 API；ignav.com 註冊取得，免信用卡）
IGNAV_API_KEY=
# Ignav 報價的市場/幣別國別（2 碼）；當所選幣別對不到內建對照表時的預設
IGNAV_MARKET=TW

# Web Push（VAPID，之後以 web-push 產生）
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# 前端
VITE_API_BASE_URL=http://localhost:3001
